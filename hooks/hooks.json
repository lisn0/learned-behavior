{
  "description": "learned-behavior — observe tool use, surface approved lessons, mine repeated failures.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/learning.py\" observe --agent claude --event-name SessionStart",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/learning.py\" advice --agent claude --workspace \"$CLAUDE_PROJECT_DIR\" --session-id \"$CLAUDE_SESSION_ID\" --output claude-json",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/learning.py\" observe --agent claude --event-name UserPromptSubmit",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/learning.py\" observe --agent claude --event-name PostToolUse",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/learning.py\" session-check --agent claude --workspace \"$CLAUDE_PROJECT_DIR\" --output stop-json",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/learning.py\" observe --agent claude --event-name SessionEnd",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/learning.py\" reinforce --session-id \"$CLAUDE_SESSION_ID\" --write",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
